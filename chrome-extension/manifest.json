{
  "manifest_version": 3,
  "name": "YourMind Web Clipper",
  "version": "1.0.0",
  "description": "Save any webpage to your multilingual second brain in one click.",
  "permissions": ["activeTab"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to YourMind",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
